// QRmenu - Prisma Schema
// Production-ready database design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum Language {
  TR
  EN
  AR
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  UNKNOWN
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  role         UserRole @default(USER)
  plan         SubscriptionPlan @default(FREE)
  planExpiresAt DateTime?
  isActive     Boolean  @default(true)
  locale       Language @default(TR)
  timezone     String   @default("Europe/Istanbul")
  unsubscribeToken String @unique @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  businesses       Business[]
  notifications    Notification[]
  notificationPref NotificationPreference?
  @@map("users")
}

// ─────────────────────────────────────────
// BUSINESSES
// ─────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  userId      String
  name        String
  slug        String   @unique
  description String?
  phone       String?
  address     String?
  logoUrl     String?
  coverUrl    String?
  currency    String   @default("TRY")
  defaultLang Language @default(TR)
  socialLinks Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menus       Menu[]
  @@map("businesses")
}

// ─────────────────────────────────────────
// MENUS
// ─────────────────────────────────────────

model Menu {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  description  String?
  isActive     Boolean  @default(false)
  isDefault    Boolean  @default(false)
  themeColor   String   @default("#FF6B35")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categories   Category[]
  qrCodes      QrCode[]
  analytics    Analytics[]
  @@map("menus")
}

// ─────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  menuId      String
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menu         Menu          @relation(fields: [menuId], references: [id], onDelete: Cascade)
  products     Product[]
  translations Translation[]
  @@map("categories")
}

// ─────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────

model Product {
  id           String   @id @default(uuid())
  categoryId   String
  name         String
  description  String?
  imageUrl     String?
  basePrice    Decimal  @db.Decimal(10, 2)
  calories     Int?
  allergens    String[]
  isAvailable  Boolean  @default(true)
  isPopular    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants     Variant[]
  extras       Extra[]
  translations Translation[]
  @@map("products")
}

// ─────────────────────────────────────────
// VARIANTS
// ─────────────────────────────────────────

model Variant {
  id        String  @id @default(uuid())
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2)
  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("variants")
}

// ─────────────────────────────────────────
// EXTRAS
// ─────────────────────────────────────────

model Extra {
  id        String  @id @default(uuid())
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2) @default(0)
  isRequired Boolean @default(false)
  maxSelect Int     @default(1)
  sortOrder Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("extras")
}

// ─────────────────────────────────────────
// TRANSLATIONS
// ─────────────────────────────────────────

model Translation {
  id         String   @id @default(uuid())
  entityType String   // 'category' | 'product'
  entityId   String
  categoryId String?
  productId  String?
  language   Language
  field      String   // 'name' | 'description'
  value      String

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, language, field])
  @@map("translations")
}

// ─────────────────────────────────────────
// QR CODES
// ─────────────────────────────────────────

model QrCode {
  id          String   @id @default(uuid())
  menuId      String
  label       String?  // e.g. "Table 1"
  tableNumber Int?
  url         String
  imageUrl    String?
  scanCount   Int      @default(0)
  createdAt   DateTime @default(now())

  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  @@map("qr_codes")
}

// ─────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────

model Analytics {
  id         String     @id @default(uuid())
  menuId     String
  deviceType DeviceType @default(UNKNOWN)
  userAgent  String?
  ipAddress  String?
  tableNumber Int?
  createdAt  DateTime   @default(now())

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  @@map("analytics")
}

enum AnalyticsEventType {
  SCAN_OPEN
  CATEGORY_VIEW
  ITEM_VIEW
  LANGUAGE_CHANGE
  SESSION_END
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  businessId  String
  menuId      String?
  type        AnalyticsEventType
  itemId      String?
  categoryId  String?
  language    String?
  sessionId   String
  tableNumber String?
  userAgent   String?
  timestamp   DateTime @default(now())
  metadata    Json?

  @@index([businessId, timestamp])
  @@index([businessId, type, timestamp])
  @@map("analytics_events")
}

model DailySnapshot {
  id             String   @id @default(cuid())
  businessId     String
  date           DateTime @db.Date
  totalScans     Int      @default(0)
  uniqueSessions Int      @default(0)
  topItems       Json
  topCategories  Json
  languageDist   Json
  hourlyDist     Json
  avgSessionMs   Int      @default(0)

  @@unique([businessId, date])
  @@index([businessId, date])
  @@map("daily_snapshots")
}

// ─────────────────────────────────────────
// INSIGHTS
// ─────────────────────────────────────────

enum InsightSeverity {
  INFO
  SUGGESTION
  IMPORTANT
}

enum InsightStatus {
  NEW
  VIEWED
  APPLIED
  DISMISSED
}

model Insight {
  id         String          @id @default(cuid())
  businessId String
  ruleId     String
  severity   InsightSeverity
  title      String
  body       String
  rawData    Json
  actionType String?
  actionData Json?
  status     InsightStatus   @default(NEW)
  weekOf     DateTime        @db.Date
  createdAt  DateTime        @default(now())

  @@unique([businessId, ruleId, weekOf])
  @@index([businessId, status, weekOf])
  @@map("insights")
}

model InsightCache {
  key       String   @id
  ruleId    String
  title     String
  body      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("insight_cache")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

enum NotificationType {
  WEEKLY_INSIGHTS_READY
  SYSTEM
}

enum NotificationChannelStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  businessId String?
  type       NotificationType
  title      String
  body       String
  data       Json?
  readAt     DateTime?
  emailStatus NotificationChannelStatus @default(PENDING)
  emailError String?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  weeklyInsightsEmail  Boolean  @default(true)
  weeklyInsightsInApp  Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
